#!/usr/bin/env bash
# Stub for networker-tester binary.
#
# Used to verify _offer_quick_test actually invokes the binary.
# STUB_TESTER_FAIL   If set to "1", exit 1

if [[ "${STUB_TESTER_FAIL:-}" == "1" ]]; then
    echo "error: connection refused" >&2
    exit 1
fi

if [[ "$1" == "--version" ]]; then
    echo "networker-tester 0.12.65"
    exit 0
fi

echo "✓ #1 [http1] 200 HTTP/1.1 Total:4.8ms"
exit 0
