{
  "version": 1,
  "tester": {
    "provider": "local"
  },
  "endpoints": [
    {
      "label": "azure-east-ubuntu",
      "provider": "azure",
      "azure": {
        "region": "eastus",
        "resource_group": "networker-rg-eastus-ubuntu",
        "vm_name": "networker-ep-eastus-ubuntu",
        "vm_size": "Standard_B2s",
        "os": "linux",
        "auto_shutdown": true
      }
    },
    {
      "label": "azure-east-windows",
      "provider": "azure",
      "azure": {
        "region": "eastus",
        "resource_group": "networker-rg-eastus-windows",
        "vm_name": "nt-east-win",
        "vm_size": "Standard_B2s",
        "os": "windows",
        "auto_shutdown": true
      }
    }
  ],
  "tests": {
    "run_tests": true,
    "modes": ["http2", "http3", "pageload2", "pageload3", "udp"],
    "runs": 20,
    "concurrency": 1,
    "timeout": 30,
    "payload_sizes": [],
    "insecure": true,
    "connection_reuse": false,
    "udp_port": 9999,
    "udp_throughput_port": 9998,
    "page_preset": "small",
    "retries": 0,
    "html_report": "azure-east-paper-report.html",
    "output_dir": "./output-azure-east-paper",
    "excel": true,
    "dns_enabled": true,
    "ipv4_only": false,
    "ipv6_only": false,
    "verbose": false
  }
}
