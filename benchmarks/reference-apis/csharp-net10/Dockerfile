# --- Build stage ---
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG TARGETARCH
WORKDIR /src
COPY csharp-net10.csproj Program.cs ./
RUN case "$TARGETARCH" in arm64) rid=linux-arm64 ;; *) rid=linux-x64 ;; esac && \
    dotnet publish -c Release -r "$rid" --self-contained -o /app/out csharp-net10.csproj

# --- Runtime stage --- (self-contained/native output: runtime-deps suffices)
FROM mcr.microsoft.com/dotnet/runtime-deps:10.0
WORKDIR /app
COPY --from=build /app/out .

ENV BENCH_CERT_DIR=/opt/bench
ENV BENCH_PORT=8443
EXPOSE 8443

ENTRYPOINT ["./csharp-net10"]
