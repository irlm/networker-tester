{
  "version": 1,

  "tester": {
    "provider": "local"
  },

  "endpoints": [
    {
      "label": "lan-server",
      "provider": "lan",
      "lan": {
        "ip": "192.168.1.100",
        "user": "admin",
        "port": 22
      }
    }
  ],

  "tests": {
    "modes": ["tcp", "http1", "http2", "http3", "udp", "download", "upload",
              "pageload", "pageload2", "pageload3"],
    "runs": 5,
    "insecure": true,
    "udp_port": 9999,
    "udp_throughput_port": 9998,
    "payload_sizes": ["64k", "1m"],
    "html_report": "report.html"
  },

  "packet_capture": {
    "mode": "none"
  }
}
